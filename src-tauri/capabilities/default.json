{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:path:default",
    "fs:default",
    "core:app:default",
    "core:image:default",
    "core:event:default",
    {
      "identifier": "core:default",
      "allow": [
        {
          "protocol": "asset",
          "scope": ["$APPLOCALDATA/**", "$LOCALDATA/**"]
        }
      ]
    }
  ]
}
