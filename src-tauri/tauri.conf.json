{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anura",
  "version": "0.1.6",
  "identifier": "com.aesir-software.anura",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Anura",
        "url": "index.html",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "binaries/mtg-sidecar"
    ],
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "src/db/scryfall.db",
      "src/db/data/variants.json.gz"
    ]
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA1ODRCQzVGNzgzMTdDMDAKUldRQWZERjRYN3lFQlJZK0NmcG1kVVp2a3daa3FHcnpodjBsaTMxMTlDRWZtT0paWVRTTTlNVkMK",
      "endpoints": [
        "https://gist.github.com/jayceovaire/4f38e54bde4c6d2a420fc1b33ec5a1e3/raw/latest.json"
      ]
    }
  }

}
